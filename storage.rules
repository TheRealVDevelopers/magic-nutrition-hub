rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // SuperAdmin can read/write everything
    match /{allPaths=**} {
      allow read, write: if request.auth != null
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'superAdmin';
    }

    // Public can read club landing pages and images
    match /clubs/{clubId}/landing/{fileName} {
      allow read: if true;
    }
    match /clubs/{clubId}/images/{fileName} {
      allow read: if true;
    }
  }
}

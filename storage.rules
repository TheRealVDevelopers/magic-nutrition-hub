rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Helper ────────────────────────────────────────────────────────────────
    // In Storage rules, each match block is evaluated independently.
    // More specific paths DO grant access even if a parent rule blocks.

    // ── Global Menu Images ─────────────────────────────────────────────────────
    // Public read, any signed-in user can upload (club owners + super admin)
    match /globalMenu/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Club Storage ───────────────────────────────────────────────────────────
    // Landing page images: public read, any signed-in user can write
    match /clubs/{clubId}/landing/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Club images folder: public read, any signed-in user can write
    match /clubs/{clubId}/images/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Product/menu images: public read, any signed-in user can write
    match /clubs/{clubId}/products/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Member profile photos: public read, any signed-in user can write
    match /clubs/{clubId}/members/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Inventory images: public read, any signed-in user can write
    match /clubs/{clubId}/inventory/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Catch-all for any other club folder (announcements, exports, etc.)
    match /clubs/{clubId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Super Admin full access (fallback) ────────────────────────────────────
    // Super admin can access everything not covered above
    match /{allPaths=**} {
      allow read, write: if request.auth != null
        && firestore.exists(
            /databases/(default)/documents/superAdmins/$(request.auth.uid)
           );
    }
  }
}

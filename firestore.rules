rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuth() { return request.auth != null; }
    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function isSuperAdmin() { return isAuth() && getRole() == 'superAdmin'; }
    function isOwnerOf(clubId) { return isAuth() && getRole() == 'clubOwner' && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clubId == clubId; }

    match /users/{userId} {
      allow read: if isAuth() && (request.auth.uid == userId || isSuperAdmin());
      allow write: if isSuperAdmin();
      allow update: if isAuth() && request.auth.uid == userId;
    }
    match /clubs/{clubId} {
      allow read: if true;
      allow write: if isSuperAdmin();
      allow update: if isOwnerOf(clubId);
    }
    match /wallets/{userId} {
      allow read: if isAuth() && (request.auth.uid == userId || isSuperAdmin() || isOwnerOf('any'));
      allow write: if isSuperAdmin();
    }
    match /walletTransactions/{txId} {
      allow read: if isAuth();
      allow write: if isSuperAdmin();
    }
    match /topupRequests/{reqId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isSuperAdmin() || isAuth() && getRole() == 'clubOwner';
    }
    match /orders/{orderId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
    }
    match /attendance/{attId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }
    match /products/{productId} {
      allow read: if true;
      allow write: if isSuperAdmin() || isAuth() && getRole() == 'clubOwner';
    }
    match /memberships/{planId} {
      allow read: if true;
      allow write: if isSuperAdmin() || isAuth() && getRole() == 'clubOwner';
    }
    match /announcements/{annId} {
      allow read: if true;
      allow write: if isAuth() && (getRole() == 'clubOwner' || isSuperAdmin());
    }
    match /billingPrints/{billId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }
    match /referrals/{refId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }
    match /platform/{docId} {
      allow read: if true;
      allow write: if isAuth();
    }
  }
}
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Super Admins ──────────────────────────────────────────────────────────
    match /superAdmins/{uid} {
      allow read, write: if true;
    }

    // ── Platform / Upgrade Requests / Billing Prints ──────────────────────────
    match /platform/{doc} {
      allow read, write: if true;
    }

    match /upgradeRequests/{reqId} {
      allow read, write: if true;
    }

    match /billingPrints/{printId} {
      allow read, write: if true;
    }

    // ── Legacy root-level enquiries (orphan fix utility) ──────────────────────
    // Allow public create so landing pages that still use old code don't break.
    // Signed-in users can read/update/delete (for the orphan-fix superadmin tool).
    match /enquiries/{enquiryId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // ── Clubs ─────────────────────────────────────────────────────────────────
    match /clubs/{clubId} {
      allow read: if true;
      allow write: if true;

      // Owner profile
      match /owner/{doc} {
        allow read, write: if true;
      }

      // All members: isPermanent:false = pending/enquiry, isPermanent:true = active member
      match /members/{memberId} {
        allow read, write: if true;

        match /wallet/{doc} {
          allow read, write: if true;
        }
        match /transactions/{txnId} {
          allow read, write: if true;
        }
        match /weighIns/{weighInId} {
          allow read, write: if true;
        }
        match /attendance/{date} {
          allow read, write: if true;
        }
        match /notifications/{notifId} {
          allow read, write: if true;
        }
      }

      match /orders/{orderId} {
        allow read, write: if true;
      }
      match /menu/{itemId} {
        allow read, write: if true;
      }
      match /announcements/{announcementId} {
        allow read, write: if true;
      }
      match /volunteers/{sessionId} {
        allow read, write: if true;
      }
      match /feedback/{feedbackId} {
        allow read, write: if true;
      }
      match /topupRequests/{requestId} {
        allow read, write: if true;
      }
      match /inventory/{itemId} {
        allow read, write: if true;
      }
      match /landingPages/{versionId} {
        allow read, write: if true;
      }
      match /transactions/{txnId} {
        allow read, write: if true;
      }
      match /memberships/{planId} {
        allow read, write: if true;
      }
      match /usageStats/{doc} {
        allow read, write: if true;
      }
      match /referrals/{refId} {
        allow read, write: if true;
      }
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────
    // HELPER FUNCTIONS
    // ─────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/superAdmins/$(request.auth.uid));
    }

    function isClubOwner(clubId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/clubs/$(clubId)).data.ownerUserId == request.auth.uid;
    }

    function isClubMember(clubId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/clubs/$(clubId)/members/$(request.auth.uid));
    }

    function isClubOwnerOrMember(clubId) {
      return isClubOwner(clubId) ||
             isClubMember(clubId);
    }

    // ─────────────────────────────────────
    // SUPER ADMINS
    // ─────────────────────────────────────

    match /superAdmins/{uid} {
      allow read: if isSignedIn() &&
        request.auth.uid == uid;
      allow write: if isSuperAdmin();
    }

    // ─────────────────────────────────────
    // GLOBAL MENU
    // ─────────────────────────────────────

    match /globalMenu/{itemId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // ─────────────────────────────────────
    // CLUBS
    // ─────────────────────────────────────

    match /clubs/{clubId} {
      // Club document itself
      allow read: if true;
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin() ||
                       isClubOwner(clubId);
      allow delete: if isSuperAdmin();

      // ── OWNER SUBCOLLECTION
      match /owner/{ownerId} {
        allow read: if isSignedIn() &&
          (isSuperAdmin() ||
           request.auth.uid == ownerId);
        allow write: if isSuperAdmin() ||
          request.auth.uid == ownerId;
      }

      // ── MEMBERS SUBCOLLECTION
      match /members/{memberId} {
        allow read: if isSignedIn() &&
          (isSuperAdmin() ||
           isClubOwner(clubId) ||
           request.auth.uid == memberId);
        allow create: if isSignedIn();
        allow update: if isSignedIn() &&
          (isSuperAdmin() ||
           isClubOwner(clubId) ||
           request.auth.uid == memberId);
        allow delete: if isSuperAdmin() ||
                         isClubOwner(clubId);

        // Member wallet
        match /wallet/{doc} {
          allow read: if isSignedIn() &&
            (isSuperAdmin() ||
             isClubOwner(clubId) ||
             request.auth.uid == memberId);
          allow write: if isSignedIn() &&
            (isSuperAdmin() ||
             isClubOwner(clubId));
        }

        // Member transactions
        match /transactions/{txnId} {
          allow read: if isSignedIn() &&
            (isSuperAdmin() ||
             isClubOwner(clubId) ||
             request.auth.uid == memberId);
          allow write: if isSignedIn() &&
            (isSuperAdmin() ||
             isClubOwner(clubId));
        }

        // Member weigh-ins
        match /weighIns/{weighInId} {
          allow read: if isSignedIn() &&
            (isSuperAdmin() ||
             isClubOwner(clubId) ||
             request.auth.uid == memberId);
          allow write: if isSignedIn() &&
            (isSuperAdmin() ||
             isClubOwner(clubId));
        }

        // Member attendance
        match /attendance/{date} {
          allow read: if isSignedIn() &&
            (isSuperAdmin() ||
             isClubOwner(clubId) ||
             request.auth.uid == memberId);
          allow write: if isSignedIn() &&
            (isSuperAdmin() ||
             isClubOwner(clubId));
        }

        // Member notifications
        match /notifications/{notifId} {
          allow read: if isSignedIn() &&
            request.auth.uid == memberId;
          allow write: if isSignedIn() &&
            (isSuperAdmin() ||
             isClubOwner(clubId));
        }
      }

      // ── ENQUIRIES
      match /enquiries/{enquiryId} {
        allow read: if isSignedIn() &&
          (isSuperAdmin() ||
           isClubOwner(clubId));
        allow create: if true;
        allow update: if isSignedIn() &&
          (isSuperAdmin() ||
           isClubOwner(clubId));
        allow delete: if isSuperAdmin() ||
                         isClubOwner(clubId);
      }

      // ── ORDERS
      match /orders/{orderId} {
        allow read: if isSignedIn() &&
          (isSuperAdmin() ||
           isClubOwner(clubId) ||
           isClubMember(clubId));
        allow create: if isSignedIn() &&
          isClubOwnerOrMember(clubId);
        allow update: if isSignedIn() &&
          (isSuperAdmin() ||
           isClubOwner(clubId));
        allow delete: if isSuperAdmin() ||
                         isClubOwner(clubId);
      }

      // ── MENU (club custom items)
      match /menu/{itemId} {
        allow read: if true;
        allow write: if isSignedIn() &&
          (isSuperAdmin() ||
           isClubOwner(clubId));
      }

      // ── MENU PREFERENCES
      match /menuPreferences/{itemId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() &&
          (isSuperAdmin() ||
           isClubOwner(clubId));
      }

      // ── TODAY'S SPECIAL
      match /todaysSpecial/{itemId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() &&
          (isSuperAdmin() ||
           isClubOwner(clubId));
      }

      // ── ANNOUNCEMENTS
      match /announcements/{announcementId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() &&
          (isSuperAdmin() ||
           isClubOwner(clubId));
      }

      // ── WALLET TOP-UP REQUESTS
      match /topupRequests/{requestId} {
        allow read: if isSignedIn() &&
          (isSuperAdmin() ||
           isClubOwner(clubId) ||
           isClubMember(clubId));
        allow create: if isSignedIn() &&
          isClubMember(clubId);
        allow update: if isSignedIn() &&
          (isSuperAdmin() ||
           isClubOwner(clubId));
        allow delete: if isSuperAdmin() ||
                         isClubOwner(clubId);
      }

      // ── VOLUNTEERS
      match /volunteers/{sessionId} {
        allow read: if isSignedIn() &&
          (isSuperAdmin() ||
           isClubOwner(clubId));
        allow write: if isSignedIn() &&
          (isSuperAdmin() ||
           isClubOwner(clubId));
      }

      // ── FEEDBACK
      match /feedback/{feedbackId} {
        allow read: if isSignedIn() &&
          (isSuperAdmin() ||
           isClubOwner(clubId));
        allow create: if true;
        allow update, delete: if isSuperAdmin() ||
                                  isClubOwner(clubId);
      }

      // ── INVENTORY
      match /inventory/{itemId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() &&
          (isSuperAdmin() ||
           isClubOwner(clubId));
      }

      // ── REPORTS
      match /reports/{reportId} {
        allow read: if isSignedIn() &&
          (isSuperAdmin() ||
           isClubOwner(clubId));
        allow write: if isSignedIn() &&
          (isSuperAdmin() ||
           isClubOwner(clubId));
      }

      // ── SETTINGS
      match /settings/{doc} {
        allow read: if isSignedIn() &&
          (isSuperAdmin() ||
           isClubOwner(clubId));
        allow write: if isSignedIn() &&
          (isSuperAdmin() ||
           isClubOwner(clubId));
      }

      // ── MENU PREFERENCES (club global items toggle)
      match /menuPreferences/{itemId} {
        allow read: if true;
        allow write: if isSignedIn() &&
          (isSuperAdmin() ||
           isClubOwner(clubId));
      }

      // ── CATCH-ALL for any other
      //    subcollections under clubs
      match /{subcollection}/{docId} {
        allow read: if isSignedIn() &&
          (isSuperAdmin() ||
           isClubOwner(clubId));
        allow write: if isSignedIn() &&
          (isSuperAdmin() ||
           isClubOwner(clubId));
      }
    }

    // ─────────────────────────────────────
    // USERS (if flat users collection exists)
    // ─────────────────────────────────────

    match /users/{uid} {
      allow read: if isSignedIn() &&
        (request.auth.uid == uid ||
         isSuperAdmin());
      allow write: if isSignedIn() &&
        (request.auth.uid == uid ||
         isSuperAdmin());
    }

    // ─────────────────────────────────────
    // ENQUIRIES (root level — legacy)
    // ─────────────────────────────────────

    match /enquiries/{enquiryId} {
      allow read: if isSuperAdmin();
      allow create: if true;
      allow update, delete: if isSuperAdmin();
    }

  }
}


rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════════════════
    // Helper functions
    // ═══════════════════════════════════════════════════════════

    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/superAdmins/$(request.auth.uid));
    }

    function isClubOwner(clubId) {
      return isSignedIn()
        && get(/databases/$(database)/documents/clubs/$(clubId)).data.ownerUserId == request.auth.uid;
    }

    function isOwnerOrSuperAdmin(clubId) {
      return isSuperAdmin() || isClubOwner(clubId);
    }

    // Since member documents use a generated ID, but Auth provides their email,
    // we cross-reference the email inside the member document to verify identity.
    function isThisMember(clubId, memberId) {
      return isSignedIn() 
        && request.auth.token.email != null
        && get(/databases/$(database)/documents/clubs/$(clubId)/members/$(memberId)).data.email == request.auth.token.email;
    }

    // ═══════════════════════════════════════════════════════════
    // Platform-level collections (root)
    // ═══════════════════════════════════════════════════════════

    // Platform config — only super admin can write
    match /platform/{doc} {
      allow read:  if isSignedIn();
      allow write: if isSuperAdmin();
    }

    // Super Admins registry
    match /superAdmins/{uid} {
      allow read:  if isSignedIn();
      allow write: if isSuperAdmin();
    }

    // Upgrade requests — anyone signed in can create, super admin manages
    match /upgradeRequests/{requestId} {
      allow read:  if isSuperAdmin();
      allow write: if isSignedIn();
    }

    // Billing print records — authenticated users
    match /billingPrints/{printId} {
      allow read, write: if isSignedIn();
    }

    // ═══════════════════════════════════════════════════════════
    // Backwards Compatibility (Legacy Flat Collections)
    // ═══════════════════════════════════════════════════════════

    // Old landing pages still try to write to the root 'enquiries' collection.
    // The superadmin has an orphan-enquiry-fix tool that reads from here.
    match /enquiries/{enquiryId} {
      // Allow public creation from old landing HTML pages
      allow create: if true;
      // Allow superAdmins to read/delete/migrate
      allow read, update, delete: if isSignedIn();
    }

    // ═══════════════════════════════════════════════════════════
    // Clubs (multi-tenancy root)
    // ═══════════════════════════════════════════════════════════

    match /clubs/{clubId} {
      // Public read needed for domain detection & club listing
      allow read:  if true;
      // Only owner or super admin can update club settings
      allow create: if isSuperAdmin();
      allow update: if isOwnerOrSuperAdmin(clubId);
      allow delete: if isSuperAdmin();

      // ───────────────────────────────────────────────────────
      // Owner profile
      // ───────────────────────────────────────────────────────
      match /owner/{doc} {
        allow read:  if isSignedIn();
        allow write: if isOwnerOrSuperAdmin(clubId);
      }

      // ───────────────────────────────────────────────────────
      // Members
      // ───────────────────────────────────────────────────────
      match /members/{memberId} {
        // Any authenticated user can read (needed for member lookup/referrals)
        allow read: if isSignedIn();
        // Owner/superAdmin can create/delete members
        // Members can ONLY update their own doc (profile edits)
        allow create: if isOwnerOrSuperAdmin(clubId);
        allow update: if isOwnerOrSuperAdmin(clubId) || isThisMember(clubId, memberId);
        allow delete: if isOwnerOrSuperAdmin(clubId);

        // ── Member wallet ──
        match /wallet/{doc} {
          allow read:  if isOwnerOrSuperAdmin(clubId) || isThisMember(clubId, memberId);
          allow write: if isOwnerOrSuperAdmin(clubId) || isThisMember(clubId, memberId);
        }

        // ── Member transactions ──
        match /transactions/{txnId} {
          allow read:  if isOwnerOrSuperAdmin(clubId) || isThisMember(clubId, memberId);
          allow write: if isOwnerOrSuperAdmin(clubId) || isThisMember(clubId, memberId);
        }

        // ── Member weigh-ins ──
        match /weighIns/{weighInId} {
          allow read:  if isOwnerOrSuperAdmin(clubId) || isThisMember(clubId, memberId);
          allow write: if isOwnerOrSuperAdmin(clubId) || isThisMember(clubId, memberId);
        }

        // ── Member attendance ──
        match /attendance/{attId} {
          allow read:  if isOwnerOrSuperAdmin(clubId) || isThisMember(clubId, memberId);
          allow write: if isOwnerOrSuperAdmin(clubId) || isThisMember(clubId, memberId);
        }

        // ── Member notifications ──
        match /notifications/{notifId} {
          allow read:  if isOwnerOrSuperAdmin(clubId) || isThisMember(clubId, memberId);
          allow write: if isOwnerOrSuperAdmin(clubId);
        }
      }

      // ───────────────────────────────────────────────────────
      // Club-level subcollections
      // ───────────────────────────────────────────────────────

      // Enquiries — public can create (landing page form), auth users read
      match /enquiries/{enquiryId} {
        allow read:   if isSignedIn();
        allow create: if true;
        allow update, delete: if isOwnerOrSuperAdmin(clubId);
      }

      // Orders — authenticated users can CRUD, but we verify they own the order
      // (Member writes their ID into order.memberId)
      // Since it's a club-level subcollection, we check data payload directly.
      match /orders/{orderId} {
        // Members can read/write if the document's memberId is theirs
        allow read:  if isOwnerOrSuperAdmin(clubId) || (isSignedIn() && resource.data.memberId != null && get(/databases/$(database)/documents/clubs/$(clubId)/members/$(resource.data.memberId)).data.email == request.auth.token.email);
        // For writes, since the doc might not exist yet during create, we check request details if possible, but owner always can
        allow create: if isOwnerOrSuperAdmin(clubId) || (isSignedIn() && request.resource.data.memberId != null && get(/databases/$(database)/documents/clubs/$(clubId)/members/$(request.resource.data.memberId)).data.email == request.auth.token.email);
        allow update: if isOwnerOrSuperAdmin(clubId) || (isSignedIn() && resource.data.memberId != null && get(/databases/$(database)/documents/clubs/$(clubId)/members/$(resource.data.memberId)).data.email == request.auth.token.email);
        allow delete: if isOwnerOrSuperAdmin(clubId);
      }

      // Menu items — everyone reads, only owner/admin writes
      match /menu/{itemId} {
        allow read:  if isSignedIn();
        allow write: if isOwnerOrSuperAdmin(clubId);
      }

      // Announcements — members read, owner/admin writes
      match /announcements/{announcementId} {
        // Members need to update readBy array
        allow read:   if isSignedIn();
        allow create: if isOwnerOrSuperAdmin(clubId);
        allow update: if isSignedIn();
        allow delete: if isOwnerOrSuperAdmin(clubId);
      }

      // Volunteer sessions — authenticated users
      match /volunteers/{sessionId} {
        allow read:  if isSignedIn();
        allow write: if isSignedIn();
      }

      // Feedback — owner reads, members write
      match /feedback/{feedbackId} {
        allow read:  if isOwnerOrSuperAdmin(clubId);
        allow write: if isSignedIn();
      }

      // Top-up requests — authenticated users can read/write their own
      match /topupRequests/{requestId} {
        allow read:  if isOwnerOrSuperAdmin(clubId) || (isSignedIn() && resource.data.memberId != null && get(/databases/$(database)/documents/clubs/$(clubId)/members/$(resource.data.memberId)).data.email == request.auth.token.email);
        allow create: if isOwnerOrSuperAdmin(clubId) || (isSignedIn() && request.resource.data.memberId != null && get(/databases/$(database)/documents/clubs/$(clubId)/members/$(request.resource.data.memberId)).data.email == request.auth.token.email);
        allow update, delete: if isOwnerOrSuperAdmin(clubId);
      }

      // Membership plans — members read, owner/admin manages
      match /memberships/{planId} {
        allow read:  if isSignedIn();
        allow write: if isOwnerOrSuperAdmin(clubId);
      }

      // Inventory — owner/admin manages
      match /inventory/{itemId} {
        allow read:  if isSignedIn();
        allow write: if isOwnerOrSuperAdmin(clubId);
      }

      // Usage stats — owner/admin reads, system writes
      match /usageStats/{doc} {
        allow read:  if isOwnerOrSuperAdmin(clubId);
        allow write: if isSignedIn();
      }
    }
  }
}
